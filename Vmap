document.getElementById('polyEditBtn').onclick = () => {
  if (!polyMenuTarget) return;
  const poly = polyMenuTarget;
  hidePolyMenu();
  if (drawingMode) {
    // 현재 그리기 중인 선 정리
    if (currentPolyline) { currentPolyline.setMap(null); polylines = polylines.filter(p => p !== currentPolyline); }
    drawingMode = false;
  }
  // 기존 선 제거 후 경로 복원해서 그리기 모드 진입
  const path = poly.getPath();
  poly.setMap(null);
  polylines = polylines.filter(p => p !== poly);

  drawingMode = true;
  currentPath = path.map(p => new kakao.maps.LatLng(p.getLat(), p.getLng()));
  currentPolyline = new kakao.maps.Polyline({ map, path: currentPath, strokeWeight: 3, strokeColor: '#FF0000', strokeOpacity: 0.8 });
  polylines.push(currentPolyline);
  attachPolylineRightClick(currentPolyline);
  document.getElementById('map').classList.add('drawing-cursor');
  // 거리 오버레이 표시
  if (currentPath.length > 0) updateDistanceOverlay(currentPath[currentPath.length - 1]);
};

// 폴리라인 우클릭/롱프레스 메뉴
function attachPolylineRightClick(poly) {
  kakao.maps.event.addListener(poly, 'rightclick', e => {
    if (drawingMode && poly === currentPolyline) return;
    showPolyMenu(lastClientX, lastClientY, poly);
  });
  // 모바일 롱프레스
  let lpTimer = null;
  kakao.maps.event.addListener(poly, 'touchstart', () => {
    lpTimer = setTimeout(() => { showPolyMenu(lastClientX, lastClientY, poly); }, 600);
  });
  kakao.maps.event.addListener(poly, 'touchend', () => clearTimeout(lpTimer));
  kakao.maps.event.addListener(poly, 'touchmove', () => clearTimeout(lpTimer));
}

// 선그리기 중 Ctrl+Z / Backspace / Escape → 이전 포인트 삭제
document.addEventListener('keydown', e => {
  if (!drawingMode || currentPath.length === 0) return;
  if (e.key === 'Backspace' || e.key === 'Escape' || (e.key === 'z' && e.ctrlKey)) {
    e.preventDefault();
    currentPath.pop();
    currentPolyline.setPath([...currentPath]);
    if (currentPath.length === 0) {
      if (distanceOverlay) { distanceOverlay.setMap(null); distanceOverlay = null; }
      if (moveLine) { moveLine.setMap(null); moveLine = null; }
    } else { updateDistanceOverlay(currentPath[currentPath.length - 1]); }
  }
});

const resetAll = () => { markers.forEach(m => { m.iw.close(); m.marker.setMap(null); }); markers = []; resetPolylines(); locationMarkerCount = 0; };

function exportGPX() {
  const activeMarkers = markers.filter(m => m.marker && m.marker.getMap()); // 지도에 남아있는 마커만
  const lastMarkerName = activeMarkers.at(-1)?.name?.trim() || 'data';
  const fname = prompt('파일명', lastMarkerName);
  if (!fname) return;

  let gpx = '<?xml version="1.0" encoding="UTF-8"?><gpx version="1.1" creator="KakaoMap">\n';

  // 트랙(선) 내보내기: (선은 기존 동작 유지하되, 화면에 보이는 선만 포함하려면 아래에 필터 추가 가능)
  polylines.forEach((pl, i) => {
    if (pl && pl.getMap()) { // 화면에 보이는 선만 포함 (getMap 존재 시)
      const pts = pl.getPath().map(p => `<trkpt lat="${p.getLat()}" lon="${p.getLng()}"></trkpt>\n`).join('');
      gpx += `<trk><name>path${i+1}</name><trkseg>\n${pts}</trkseg></trk>\n`;
    }
  });

  // 활성 마커만 내보내기
  activeMarkers.forEach(m => {
    const p = m.marker.getPosition3();
    gpx += `<wpt lat="${p.getLat()}" lon="${p.getLng()}"><name>${m.name || ''}</name></wpt>\n`;
  });

  gpx += '</gpx>';

  const blob = new Blob([gpx], { type: 'application/gpx+xml' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = fname + '.gpx';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
}


// ─── CSV 내보내기 ─────────────────────────────────────
async function exportCSV() {
  const activeMarkers = markers.filter(m => m.marker && m.marker.getMap());
  if (activeMarkers.length === 0) { alert('내보낼 마커가 없습니다.'); return; }

  const fname = prompt('CSV 파일명', document.getElementById('address-display').innerText.split(' ')[0] || 'markers');
  if (!fname) return;

  // 주소 없는 마커 역지오코딩
  const getAddr = (m) => new Promise(resolve => {
    if (m.addr !== undefined) { resolve(m.addr); return; }
    const pos = m.marker.getPosition3();
    geocoder.coord2Address(pos.getLng(), pos.getLat(), (res, status) => {
      if (status === kakao.maps.services.Status.OK) {
        const addr = res[0].address?.address_name || '';
        m.addr = addr;
        resolve(addr);
      } else {
        resolve('');
      }
    });
  });

  // 헤더 (BOM 포함으로 엑셀 한글 깨짐 방지)
  let csv = '\uFEFF이름,위도,경도,주소\n';

  for (let idx = 0; idx < activeMarkers.length; idx++) {
    const m = activeMarkers[idx];
    const pos = m.marker.getPosition ? m.marker.getPosition3() : null;
    if (!pos) continue;
    const lat = pos.getLat();
    const lng = pos.getLng();
    const name = (m.name || '').replace(/"/g, '""');
    const addr = (await getAddr(m)).replace(/"/g, '""');

    csv += `"${name}",${lat},${lng},"${addr}"\n`;
  }

  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = fname + '.csv';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(() => URL.revokeObjectURL(a.href), 1000);
}

function exportByFormat() {
  const format = document.getElementById('exportFormat').value;
  const area   = document.getElementById('exportArea').value;
  if (format === 'kmz') { area === 'visible' ? exportVisibleKMZ() : exportKMZ(); }
  else if (format === 'gpx') { area === 'visible' ? exportVisibleGPX() : exportGPX(); }
  else if (format === 'csv') exportCSV();
}

async function exportKMZ() {
  const activeMarkers = markers.filter(m => m.marker && m.marker.getMap());

  // 주소+날짜+마커 기본 파일명 생성
  const now = new Date();
  const dateStr = now.getFullYear().toString() +
                  (now.getMonth()+1).toString().padStart(2,'0') +
                  now.getDate().toString().padStart(2,'0');

  const getAddrPrefix = () => new Promise(resolve => {
    const center = map.getCenter();
    geocoder.coord2Address(center.getLng(), center.getLat(), (result, status) => {
      if (status !== kakao.maps.services.Status.OK || !result[0]) { resolve(''); return; }
      const parts = (result[0].address?.address_name || '').split(' ').filter(p => !/^\d/.test(p));
      const eupMyeon = parts.find(p => /[읍면]$/.test(p)) || '';
      const ri       = parts.find(p => /리$/.test(p)) || '';
      const gu   = parts.find(p => /구$/.test(p)) || '';
      const dong = [...parts].reverse().find(p => /동(\d+가)?$/.test(p)) || '';
      let prefix = '';
      if (eupMyeon && ri)      prefix = `${eupMyeon.replace(/[읍면]$/, '')}${ri}_`;
      else if (eupMyeon)       prefix = `${eupMyeon}_`;
      else if (gu && dong)     prefix = `${gu.replace(/구$/, '')}${dong}_`;
      else if (gu)             prefix = `${gu.replace(/구$/, '')}_`;
      else if (dong)           prefix = `${dong}_`;
      resolve(prefix);
    });
  });

  const prefix = await getAddrPrefix();
  const lastMarkerRaw = ([...activeMarkers].reverse().find(m => !m.iw.getContent().querySelector('img'))?.name
                        || activeMarkers.at(-1)?.name || '');
  const lastMarkerName = lastMarkerRaw.replace(/_\d{8}.*$/, '').replace(/[\\/:*?"<>|]/g, '').trim();
  const defaultName = lastMarkerName
    ? `${prefix}${dateStr}_${lastMarkerName}`
    : `${prefix}${dateStr}_`;

  const fname = prompt('파일명', defaultName);
  if (!fname) return;

  const zip = new JSZip();
  const photoFiles = []; // { filename, dataUrl }

  // 사진 마커에서 이미지 추출 (파일명 중복 방지용 인덱스 추가)
  let photoCount = 0;
  for (const m of activeMarkers) {
    const img = m.iw.getContent().querySelector('img');
    if (img && img.src.startsWith('data:image')) {
      photoCount++;
      const safeName = (m.name || 'photo').replace(/[^\w가-힣\-_.]/g, '_');
      const safeFilename = `${photoCount}_${safeName}.jpg`;
      photoFiles.push({ filename: safeFilename, markerName: m.name });
      const compressed = await compressImage(img.src);
      zip.file(`files/${safeFilename}`, compressed.split(',')[1], { base64: true });
    }
  }

  // KML 생성
  let kml = `<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>${fname}</name>\n`;

  // 선(트랙) → KML LineString
  polylines.forEach((pl, i) => {
    if (!pl || !pl.getMap()) return;
    const coords = pl.getPath().map(p => `${p.getLng()},${p.getLat()},0`).join('\n          ');
    kml += `  <Placemark>
    <name>path${i + 1}</name>
    <LineString><coordinates>
          ${coords}
    </coordinates></LineString>
  </Placemark>\n`;
  });

  // 마커 → KML Placemark
  let photoIdx = 0;
  for (const m of activeMarkers) {
    const p = m.marker.getPosition3();
    const img = m.iw.getContent().querySelector('img');
    if (img && img.src.startsWith('data:image')) {
      const safeFilename = photoFiles[photoIdx]?.filename || 'photo.jpg';
      photoIdx++;
      kml += `  <Placemark>
    <name>${m.name || ''}</name>
    <description><![CDATA[<img src="files/${safeFilename}" style="max-width:400px">]]></description>
    <ExtendedData><Data name="photoFile"><value>${safeFilename}</value></Data></ExtendedData>
    <Point><coordinates>${p.getLng()},${p.getLat()},0</coordinates></Point>
  </Placemark>\n`;
    } else {
      kml += `  <Placemark>
    <name>${m.name || ''}</name>
    <Point><coordinates>${p.getLng()},${p.getLat()},0</coordinates></Point>
  </Placemark>\n`;
    }
  }

  kml += `</Document>\n</kml>`;
  zip.file('doc.kml', kml);

  const blob = await zip.generateAsync({ type: 'blob' });
  const kmzFile = new File([blob], fname + '.kmz', { type: 'application/vnd.google-earth.kmz' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(kmzFile);
  a.download = fname + '.kmz';
  document.body.appendChild(a);
  a.click();
  setTimeout(() => { document.body.removeChild(a); URL.revokeObjectURL(a.href); }, 1000);
}


function exportVisibleGPX() {
  const bounds = map.getBounds();

  // 먼저 지도에 붙어있는 활성 마커만 고려
  const activeMarkers = markers.filter(m => m.marker && m.marker.getMap());

  // 보이는 영역 안에 있는 활성 마커만
  const visibleMarkers = activeMarkers.filter(m =>
    bounds.contain(m.marker.getPosition3())
  );

  // 보이는 영역에 포함되는 선(폴리라인)만 선택
  const visiblePolylines = polylines.filter(pl =>
    pl && pl.getMap() && pl.getPath().some(p => bounds.contain(p))
  );

  const defaultName = visibleMarkers.at(-1)?.name?.trim() || 'visible_data';
  const fname = prompt('보이는 영역의 GPX 저장 파일명', defaultName);
  if (!fname) return;

  let gpx = '<?xml version="1.0" encoding="UTF-8"?><gpx version="1.1" creator="KakaoMap">\n';

  visiblePolylines.forEach((pl, i) => {
    gpx += `<trk><name>path${i+1}</name><trkseg>\n` +
      pl.getPath()
        .filter(p => bounds.contain(p))
        .map(p => `<trkpt lat="${p.getLat()}" lon="${p.getLng()}"></trkpt>\n`)
        .join('') +
      '</trkseg></trk>\n';
  });

  visibleMarkers.forEach(m => {
    const p = m.marker.getPosition3();
    gpx += `<wpt lat="${p.getLat()}" lon="${p.getLng()}"><name>${m.name || ''}</name></wpt>\n`;
