<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <title>KMZ & 사진 지도 (v1.0)</title>
  <script src="https://cdn.jsdelivr.net/npm/ol@9.2.4/dist/ol.js"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ol@9.2.4/dist/ol.css">
  <script>
  // ── v월드 + OpenLayers 카카오맵 호환 레이어 ──────────────────
  const VWORLD_KEY = '58F6D8A1-7DF7-3DF7-95C7-75A441DC576C';

  // 좌표 변환 유틸
  function toLonLat(lat, lng) { return ol.proj.fromLonLat([lng, lat]); }
  function fromLonLat(coord) { const ll = ol.proj.toLonLat(coord); return { lat: ll[1], lng: ll[0] }; }

  // ── kakao 네임스페이스 호환 ──────────────────────────────────
  const kakao = {
    maps: {
      // LatLng
      LatLng: function(lat, lng) {
        this._lat = lat; this._lng = lng;
        this.getLat = () => this._lat;
        this.getLng = () => this._lng;
        this.toCoord = () => toLonLat(lat, lng);
      },
      // LatLngBounds
      LatLngBounds: function() {
        this._coords = [];
        this.extend = (ll) => { this._coords.push([ll._lng, ll._lat]); };
        this.isEmpty = () => this._coords.length === 0;
        this.toExtent = function() {
          const lngs = this._coords.map(c=>c[0]), lats = this._coords.map(c=>c[1]);
          return ol.proj.transformExtent(
            [Math.min(...lngs),Math.min(...lats),Math.max(...lngs),Math.max(...lats)],
            'EPSG:4326','EPSG:3857'
          );
        };
      },
      // Map
      Map: function(el, opts) {
        const center = opts.center ? toLonLat(opts.center._lat, opts.center._lng) : ol.proj.fromLonLat([127.5,35.9]);
        const zoom = opts.level ? Math.max(1, 19 - opts.level) : 14;

        const layers = {
          Base: new ol.layer.Tile({ source: new ol.source.XYZ({
            url: `https://api.vworld.kr/req/wmts/1.0.0/${VWORLD_KEY}/Base/{z}/{x}/{y}.png`,
            maxZoom: 19
          })}),
          Satellite: new ol.layer.Tile({ source: new ol.source.XYZ({
            url: `https://api.vworld.kr/req/wmts/1.0.0/${VWORLD_KEY}/Satellite/{z}/{x}/{y}.jpeg`,
            maxZoom: 19
          }), visible: false }),
          Hybrid: new ol.layer.Tile({ source: new ol.source.XYZ({
            url: `https://api.vworld.kr/req/wmts/1.0.0/${VWORLD_KEY}/Hybrid/{z}/{x}/{y}.png`,
            maxZoom: 19
          }), visible: false }),
          Gray: new ol.layer.Tile({ source: new ol.source.XYZ({
            url: `https://api.vworld.kr/req/wmts/1.0.0/${VWORLD_KEY}/gray/{z}/{x}/{y}.png`,
            maxZoom: 19
          }), visible: false }),
        };

        const olMap = new ol.Map({
          target: el,
          layers: [layers.Base, layers.Satellite, layers.Hybrid, layers.Gray],
          view: new ol.View({ center, zoom, projection: 'EPSG:3857' }),
          controls: []
        });

        // 마커/오버레이 레이어
        const markerSource = new ol.source.Vector();
        const markerLayer = new ol.layer.Vector({ source: markerSource, zIndex: 10 });
        olMap.addLayer(markerLayer);
        olMap._markerSource = markerSource;

        // 지도 타입 선택기 추가
        const typeCtrl = document.createElement('select');
        typeCtrl.style.cssText = 'position:absolute;top:10px;right:10px;z-index:1000;padding:5px 8px;border-radius:6px;border:1px solid #ccc;background:white;font-size:13px;cursor:pointer;';
        typeCtrl.innerHTML = '<option value="Base">일반지도</option><option value="Satellite">위성영상</option><option value="Hybrid" selected>하이브리드</option><option value="Gray">백지도</option>';
        typeCtrl.onchange = function() {
          Object.keys(layers).forEach(k => layers[k].setVisible(k === this.value || (this.value === 'Hybrid' && k === 'Satellite')));
          if (this.value === 'Hybrid') { layers.Satellite.setVisible(true); layers.Hybrid.setVisible(true); }
        };
        // 초기: Hybrid = Satellite + Hybrid 레이어
        layers.Satellite.setVisible(true);
        layers.Hybrid.setVisible(true);
        el.style.position = 'relative';
        el.appendChild(typeCtrl);

        // getCenter
        olMap.getCenter = function() {
          const c = olMap.getView().getCenter();
          const ll = ol.proj.toLonLat(c);
          return new kakao.maps.LatLng(ll[1], ll[0]);
        };
        // setCenter
        olMap.setCenter = function(latlng) {
          olMap.getView().setCenter(toLonLat(latlng._lat, latlng._lng));
        };
        // panTo
        olMap.panTo = olMap.setCenter;
        // getLevel / setLevel
        olMap.getLevel = function() { return Math.max(1, 19 - Math.round(olMap.getView().getZoom())); };
        olMap.setLevel = function(lvl) { olMap.getView().setZoom(19 - lvl); };
        // setBounds
        olMap.setBounds = function(bounds) {
          if (!bounds || bounds.isEmpty()) return;
          olMap.getView().fit(bounds.toExtent(), { padding:[60,60,60,60], maxZoom:17, duration:300 });
        };
        // getProjection (픽셀↔좌표 변환용)
        olMap.getProjection = function() {
          return {
            pointFromCoords: (ll) => {
              const px = olMap.getPixelFromCoordinate(toLonLat(ll._lat, ll._lng));
              return { x: px ? px[0] : 0, y: px ? px[1] : 0 };
            },
            coordsFromPoint: (pt) => {
              const coord = olMap.getCoordinateFromPixel([pt.x, pt.y]);
              const ll = ol.proj.toLonLat(coord);
              return new kakao.maps.LatLng(ll[1], ll[0]);
            }
          };
        };
        // 이벤트
        olMap._listeners = {};
        return olMap;
      },
      // Marker
      Marker: function(opts) {
        const latlng = opts.position;
        const el = document.createElement('div');
        el.style.cssText = 'width:30px;height:40px;cursor:pointer;';
        el.innerHTML = `<svg viewBox="0 0 30 40" xmlns="http://www.w3.org/2000/svg"><path d="M15 0C7 0 0 7 0 15c0 10 15 25 15 25S30 25 30 15C30 7 23 0 15 0z" fill="#FF4444"/><circle cx="15" cy="15" r="6" fill="white"/></svg>`;
        const overlay = new ol.Overlay({ element: el, positioning: 'bottom-center', stopEvent: false });
        overlay.setPosition(toLonLat(latlng._lat, latlng._lng));
        overlay._latlng = latlng;
        overlay._el = el;
        overlay.getPosition2 = () => overlay._latlng;
        overlay.getPosition3 = () => {
          const p = overlay.getPosition3();
          const ll = ol.proj.toLonLat(p);
          return new kakao.maps.LatLng(ll[1], ll[0]);
        };
        overlay.setMap = function(m) {
          if (m) { m.addOverlay(overlay); overlay._map = m; }
          else { if (overlay._map) overlay._map.removeOverlay(overlay); overlay._map = null; }
        };
        overlay.getMap = function() { return overlay._map || null; };
        overlay.setPosition2 = function(latlng) {
          overlay._latlng = latlng;
          overlay.setPosition(toLonLat(latlng._lat, latlng._lng));
        };
        overlay.setDraggable = function(v) {
          if (!v) return;
          let dragging = false, startPx, startCoord;
          el.addEventListener('mousedown', e => {
            dragging = true; startPx = [e.clientX, e.clientY];
            startCoord = overlay.getPosition3();
            e.preventDefault();
          });
          document.addEventListener('mousemove', e => {
            if (!dragging) return;
            const dx = e.clientX - startPx[0], dy = e.clientY - startPx[1];
            const newPx = overlay._map.getPixelFromCoordinate(startCoord);
            const newCoord = overlay._map.getCoordinateFromPixel([newPx[0]+dx, newPx[1]+dy]);
            overlay.setPosition(newCoord);
            const ll = ol.proj.toLonLat(newCoord);
            overlay._latlng = new kakao.maps.LatLng(ll[1], ll[0]);
          });
          document.addEventListener('mouseup', () => {
            if (dragging) {
              dragging = false;
              overlay._el.dispatchEvent(new CustomEvent('position_changed'));
            }
          });
        };
        if (opts.map) overlay.setMap(opts.map);
        return overlay;
      },
      // Polyline
      Polyline: function(opts) {
        const feature = new ol.Feature();
        const style = new ol.style.Style({
          stroke: new ol.style.Stroke({
            color: opts.strokeColor || '#FF5733',
            width: opts.strokeWeight || 3,
            opacity: opts.strokeOpacity || 0.9
          })
        });
        feature.setStyle(style);
        feature._map = null;
        feature._source = null;

        if (opts.path && opts.path.length) {
          feature.setGeometry(new ol.geom.LineString(
            opts.path.map(ll => toLonLat(ll._lat, ll._lng))
          ));
        }
        feature.setPath = function(path) {
          if (!path || path.length < 2) { feature.setGeometry(null); return; }
          feature.setGeometry(new ol.geom.LineString(path.map(ll => toLonLat(ll._lat, ll._lng))));
        };
        feature.getPath = function() {
          const geom = feature.getGeometry();
          if (!geom) return [];
          return geom.getCoordinates().map(c => { const ll = ol.proj.toLonLat(c); return new kakao.maps.LatLng(ll[1], ll[0]); });
        };
        feature.getLength = function() {
          const geom = feature.getGeometry();
          if (!geom) return 0;
          return ol.sphere.getLength(geom);
        };
        feature.setMap = function(m) {
          if (feature._source) { feature._source.removeFeature(feature); feature._source = null; }
          if (m) { m._markerSource.addFeature(feature); feature._source = m._markerSource; feature._map = m; }
          else { feature._map = null; }
        };
        feature.getMap = function() { return feature._map; };
        if (opts.map) feature.setMap(opts.map);
        return feature;
      },
      // CustomOverlay
      CustomOverlay: function(opts) {
        const el = typeof opts.content === 'string' ? (() => { const d = document.createElement('div'); d.innerHTML = opts.content; return d; })() : opts.content;
        const overlay = new ol.Overlay({ element: el, positioning: opts.yAnchor ? 'bottom-center' : 'top-left', stopEvent: true });
        overlay.setMap = function(m) {
          if (m) { m.addOverlay(overlay); overlay._map = m; }
          else { if (overlay._map) overlay._map.removeOverlay(overlay); overlay._map = null; }
        };
        overlay.getMap = function() { return overlay._map || null; };
        overlay.setPosition2 = function(latlng) { overlay.setPosition(toLonLat(latlng._lat, latlng._lng)); };
        overlay.setContent = function(c) { el.innerHTML = typeof c === 'string' ? c : ''; };
        overlay.getContent = function() { return el; };
        if (opts.position) overlay.setPosition(toLonLat(opts.position._lat, opts.position._lng));
        if (opts.map) overlay.setMap(opts.map);
        return overlay;
      },
      // InfoWindow
      InfoWindow: function(opts) {
        const content = typeof opts.content === 'string' ? (() => { const d = document.createElement('div'); d.innerHTML = opts.content; d.style.cssText='background:white;border-radius:8px;padding:8px 10px;box-shadow:0 2px 8px rgba(0,0,0,0.3);min-width:100px;position:relative;'; return d; })() : opts.content;
        // 닫기 버튼
        if (opts.removable) {
          const btn = document.createElement('span');
          btn.textContent = '✕'; btn.style.cssText = 'position:absolute;top:4px;right:6px;cursor:pointer;color:#999;font-size:12px;';
          btn.onclick = () => overlay.close();
          content.appendChild(btn);
        }
        const overlay = new ol.Overlay({ element: content, positioning: 'bottom-center', stopEvent: true, offset: [0, -10] });
        overlay._map = null;
        overlay._marker = null;
        overlay.open = function(m, marker) {
          overlay._map = m; overlay._marker = marker;
          const pos = marker ? marker.getPosition3() : null;
          if (pos) overlay.setPosition(pos);
          m.addOverlay(overlay);
        };
        overlay.close = function() { if (overlay._map) overlay._map.removeOverlay(overlay); };
        overlay.getContent = function() { return content; };
        overlay.setContent2 = function(c) { if (typeof c === 'string') content.innerHTML = c; };
        return overlay;
      },
      // event
      event: {
        addListener: function(target, type, handler) {
          if (!target || !type) return;
          if (target instanceof ol.Map) {
            if (type === 'click') {
              target.on('click', function(e) {
                const ll = ol.proj.toLonLat(e.coordinate);
                const latlng = new kakao.maps.LatLng(ll[1], ll[0]);
                handler({ latLng: latlng, clientX: e.originalEvent?.clientX, clientY: e.originalEvent?.clientY });
              });
            } else if (type === 'rightclick') {
              target.getViewport().addEventListener('contextmenu', function(e) {
                e.preventDefault();
                const px = target.getEventPixel(e);
                const coord = target.getCoordinateFromPixel(px);
                const ll = ol.proj.toLonLat(coord);
                handler({ latLng: new kakao.maps.LatLng(ll[1], ll[0]), clientX: e.clientX, clientY: e.clientY });
              });
            } else if (type === 'mousemove') {
              target.on('pointermove', function(e) {
                const ll = ol.proj.toLonLat(e.coordinate);
                handler({ latLng: new kakao.maps.LatLng(ll[1], ll[0]), clientX: e.originalEvent?.clientX, clientY: e.originalEvent?.clientY });
              });
            } else if (type === 'zoom_changed') {
              target.getView().on('change:resolution', handler);
            }
          } else if (target._el) {
            // Marker overlay
            if (type === 'click') {
              target._el.addEventListener('click', function(e) {
                e.stopPropagation();
                handler({ latLng: target._latlng });
              });
            } else if (type === 'rightclick') {
              target._el.addEventListener('contextmenu', function(e) {
                e.preventDefault(); e.stopPropagation();
                handler({ latLng: target._latlng, clientX: e.clientX, clientY: e.clientY });
              });
            } else if (type === 'position_changed') {
              target._el.addEventListener('position_changed', handler);
            }
          } else if (target instanceof ol.Feature) {
            // Polyline feature
            if (type === 'rightclick' && target._source) {
              // handled via map rightclick
              if (!target._rcHandlers) target._rcHandlers = [];
              target._rcHandlers.push(handler);
            }
          }
        }
      },
      // MapTypeId (더미)
      MapTypeId: { HYBRID: 'Hybrid', ROADMAP: 'Base', SATELLITE: 'Satellite' },
      // services
      services: {
        Status: { OK: 'OK' },
        Geocoder: function() {
          this.coord2Address = function(lng, lat, callback) {
            fetch(`https://api.vworld.kr/req/address?service=address&request=getAddress&version=2.0&crs=epsg:4326&point=${lng},${lat}&format=json&type=both&key=${VWORLD_KEY}`)
              .then(r => r.json())
              .then(data => {
                if (data.response?.status === 'OK' && data.response?.result?.length) {
                  const addr = data.response.result[0];
                  callback([{ address: { address_name: addr.text || '' } }], 'OK');
                } else { callback([], 'ZERO_RESULTS'); }
              })
              .catch(() => callback([], 'ERROR'));
          };
          this.addressSearch = function(query, callback) {
            fetch(`https://api.vworld.kr/req/search?service=search&request=search&version=2.0&crs=epsg:4326&size=10&page=1&query=${encodeURIComponent(query)}&type=address&format=json&key=${VWORLD_KEY}`)
              .then(r => r.json())
              .then(data => {
                if (data.response?.status === 'OK') {
                  const items = data.response.result?.items || [];
                  const results = items.map(item => ({
                    address_name: item.address?.parcel || item.title,
                    x: item.point?.x, y: item.point?.y,
                    road_address: item.address?.road ? { address_name: item.address.road } : null
                  }));
                  callback(results, 'OK');
                } else { callback([], 'ZERO_RESULTS'); }
              })
              .catch(() => callback([], 'ERROR'));
          };
        }
      },
      // Point
      Point: function(x, y) { this.x = x; this.y = y; }
    }
  };

  // getPosition → getPosition3 (LatLng 반환)
  // setMap(null) 처리를 위한 글로벌 map 변수 접근

  // Polyline rightclick 처리 (지도 rightclick 이벤트에서 가장 가까운 feature 탐색)
  function setupPolylineRightClick(olMap) {
    if (!olMap || !olMap.getViewport) return;
    olMap.getViewport().addEventListener('contextmenu', function(e) {
      e.preventDefault();
      const px = olMap.getEventPixel(e);
      olMap.forEachFeatureAtPixel(px, function(feature) {
        if (feature._rcHandlers) {
          feature._rcHandlers.forEach(h => h({ latLng: olMap.getCenter(), clientX: e.clientX, clientY: e.clientY }));
          return true;
        }
      }, { hitTolerance: 8 });
    });
  }
  </script>
