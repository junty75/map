function copyAndMarkLocation() {
  const val = document.getElementById('latlng-display').value;
  if (!val) return;
  const parts = val.split(',');
  const lat = parts[0]?.trim();
  const lng = parts[1]?.trim();
  const addr = document.getElementById('address-display').innerText;
  if (!lat || !lng) return;
  const text = `${lat}\t${lng}\t${addr}`;
  navigator.clipboard.writeText(text).then(() => {
    createLocationMarker(parseFloat(lat), parseFloat(lng));
    const el = document.getElementById('address-display');
    const prev = el.innerText;
    el.innerText = '✅ 복사됨';
    setTimeout(() => { el.innerText = prev; }, 1200);
  }).catch(() => {
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.style.position = 'fixed'; ta.style.opacity = '0';
    document.body.appendChild(ta); ta.select(); document.execCommand('copy');
    document.body.removeChild(ta);
    createLocationMarker(parseFloat(lat), parseFloat(lng));
  });
}

function createLocationMarker(lat, lng) {
  locationMarkerCount++;
  const latlng = new kakao.maps.LatLng(lat, lng);
  const addr = document.getElementById('address-display').innerText;
  addMarker(latlng, String(locationMarkerCount));
