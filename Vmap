document.addEventListener('dragover', e => e.preventDefault());
document.addEventListener('drop', e => {
  e.preventDefault();
  const files = Array.from(e.dataTransfer.files);
  if (!files.length) return;
  const bounds = new kakao.maps.LatLngBounds();
  let photoWithoutGPSAction = null;

  files.forEach(file => {
    const name = file.name.toLowerCase();

    // 0) KMZ / ZIP 불러오기 (.zip은 휴대폰에서 .kmz가 .kmz.zip으로 저장될 때 대응)
    if (name.endsWith('.kmz') || name.endsWith('.zip')) {
      loadKMZ(file, bounds);

    // 0-1) HTM / HTML — 카카오맵 좌표 추출
    } else if (name.endsWith('.htm') || name.endsWith('.html')) {
      const reader = new FileReader();
      reader.onload = ev => {
        const html = ev.target.result;

        // 폴리라인/폴리곤 추출: linePath\d+, polygonPath\d+ 모두 처리
        const lineBlocks = [...html.matchAll(/var\s+(linePath\d+|polygonPath\d+)\s*=\s*\[([\s\S]*?)\];/g)];
        lineBlocks.forEach((m, i) => {
          const pts = [...m[2].matchAll(/new\s+kakao\.maps\.LatLng\(([\d.]+),([\d.]+)\)/g)]
            .map(c => { const ll = new kakao.maps.LatLng(parseFloat(c[1]), parseFloat(c[2])); bounds.extend(ll); return ll; });
          if (pts.length < 2) return;
          const poly = new kakao.maps.Polyline({ map, path: pts, strokeWeight: 3, strokeColor: '#FF00FF', strokeOpacity: 0.85 });
          polylines.push(poly);
          attachPolylineRightClick(poly);
        });

        // 마커 추출: positions 배열 또는 개별 Marker 선언
        // 방식1: positions 배열 { content: '...', latlng: new kakao.maps.LatLng(...) }
        const posMatches = [...html.matchAll(/content:\s*'([^']*)'[\s\S]*?latlng:\s*new\s+kakao\.maps\.LatLng\(([\d.]+),([\d.]+)\)/g)];
        posMatches.forEach(m => {
          const rawHtml = m[1];
          const rawName = rawHtml
            .replace(/<a\b[^>]*>.*?<\/a>/gi, '')
            .replace(/<[^>]+>/g, '')
            .trim() || '마커';
          const ll = new kakao.maps.LatLng(parseFloat(m[2]), parseFloat(m[3]));
          bounds.extend(ll);
          addMarker(ll, rawName);
        });

        // 방식2: new kakao.maps.Marker({ position: new kakao.maps.LatLng(...) })
        if (posMatches.length === 0) {
          const mkMatches = [...html.matchAll(/new\s+kakao\.maps\.Marker\s*\(\s*\{[^}]*position:\s*new\s+kakao\.maps\.LatLng\(([\d.]+),([\d.]+)\)/g)];
          mkMatches.forEach((m, i) => {
            const ll = new kakao.maps.LatLng(parseFloat(m[1]), parseFloat(m[2]));
            bounds.extend(ll);
            addMarker(ll, `마커_${i+1}`);
          });
        }

        if (!bounds.isEmpty()) map.setBounds(bounds);
        document.getElementById('saveBtn') && (document.getElementById('saveBtn').disabled = false);
      };
      reader.readAsText(file, 'utf-8');

    // 1) GPX
    } else if (name.endsWith('.gpx')) {
      const reader = new FileReader();
      reader.onload = ev => {
        const xml = new DOMParser().parseFromString(ev.target.result, 'application/xml');
        Array.from(xml.getElementsByTagName('trk')).forEach((trk, index) => {
          const trackName = trk.getElementsByTagName('name')[0]?.textContent || `path${index + 1}`;
          Array.from(trk.getElementsByTagName('trkseg')).forEach(seg => {
            const pts = Array.from(seg.getElementsByTagName('trkpt')).map(pt => {
              const ll = new kakao.maps.LatLng(parseFloat(pt.getAttribute('lat')), parseFloat(pt.getAttribute('lon')));
              bounds.extend(ll);
              return ll;
            });
            if (pts.length) {
              const poly = new kakao.maps.Polyline({ map, path: pts, strokeWeight: 4, strokeColor: getRandomColor(), strokeOpacity: 0.9 });
              const distance = poly.getLength();
              const formatDistance = d => d <= 10 ? `${d.toFixed(1)}m` : d < 1000 ? `${Math.round(d)}m` : `${(d/1000).toFixed(2)}km`;
              const overlay = new kakao.maps.CustomOverlay({
                content: `<div style="padding:5px 8px;background:white;border:1px solid #333;font-size:1.0em;border-radius:3px;"><b>${trackName}</b><br>총거리: ${formatDistance(distance)}</div>`,
                yAnchor: 1, zIndex: 4
              });
              kakao.maps.event.addListener(poly, 'mouseover', () => { const _mid = poly.getPath()[Math.floor(pts.length/2)]; if (_mid) { overlay.setPosition2(_mid); overlay.setMap(map); } });
              kakao.maps.event.addListener(poly, 'mouseout', () => overlay.setMap(null));
              polylines.push(poly);
              attachPolylineRightClick(poly);
            }
          });
        });
        Array.from(xml.getElementsByTagName('wpt')).forEach(wpt => {
          const ll = new kakao.maps.LatLng(parseFloat(wpt.getAttribute('lat')), parseFloat(wpt.getAttribute('lon')));
          bounds.extend(ll);
          addMarker(ll, wpt.getElementsByTagName('name')[0]?.textContent || '설명 없음');
        });
        if (!bounds.isEmpty()) map.setBounds(bounds);
      };
      reader.readAsText(file);

    // 2) 이미지
    } else if (file.type.startsWith('image/') || /\.(jpe?g|png)$/i.test(name)) {
      const reader = new FileReader();
      reader.onload = ev => {
        const imgSrc = ev.target.result;
        const imgName = file.name.replace(/\.[^/.]+$/, '');

        // piexif로 EXIF GPS 읽기
        let latlng = null;
        try {
          const exif = piexif.load(imgSrc);
          const gps = exif['GPS'];
          if (gps && gps[piexif.GPSIFD.GPSLatitude] && gps[piexif.GPSIFD.GPSLongitude]) {
            const toDec = (dms, ref) => {
              const d = dms[0][0]/dms[0][1];
              const m = dms[1][0]/dms[1][1];
              const s = dms[2][0]/dms[2][1];
              return (d + m/60 + s/3600) * ((ref === 'S' || ref === 'W') ? -1 : 1);
            };
            const lat = toDec(gps[piexif.GPSIFD.GPSLatitude],  gps[piexif.GPSIFD.GPSLatitudeRef]  || 'N');
            const lng = toDec(gps[piexif.GPSIFD.GPSLongitude], gps[piexif.GPSIFD.GPSLongitudeRef] || 'E');
            if (!isNaN(lat) && !isNaN(lng) && (lat !== 0 || lng !== 0)) {
              latlng = new kakao.maps.LatLng(lat, lng);
            }
          }
        } catch(ex) {}

        if (latlng) {
          bounds.extend(latlng);
          addPhotoMarker(latlng, imgSrc, imgName);
          if (!bounds.isEmpty()) map.setBounds(bounds);
        } else {
          if (photoWithoutGPSAction === null) {
            photoWithoutGPSAction = confirm(`"${file.name}" 사진에 위치 정보가 없습니다.\n지도 중심에 마커를 추가하시겠습니까?\n(이 선택은 이번에 올리는 모든 사진에 적용됩니다)`);
          }
          if (photoWithoutGPSAction) {
            const center = map.getCenter();
            addPhotoMarker(center, imgSrc, imgName);
            map.panTo(center);
            const added = markers.at(-1);
            if (added) { added.marker.setDraggable(true); movingPhotoMarker = added; }
          }
        }
      };
      reader.readAsDataURL(file);

    // 3) CSV — 헤더 자동 감지 (이름/위도/경도/주소 컬럼 순서 무관)
    } else if (name.endsWith('.csv')) {
      const reader = new FileReader();
      reader.onload = evt => {
        const text = evt.target.result.replace(/^\uFEFF/, ''); // BOM 제거
        const lines = text.trim().split(/\r?\n/);
        if (lines.length < 2) return;

        // CSV 한 줄 파싱 (따옴표 안 쉼표 처리)
        function parseCSVLine(line) {
          const result = [];
          let cur = '', inQ = false;
          for (let i = 0; i < line.length; i++) {
            const ch = line[i];
            if (ch === '"') { inQ = !inQ; }
            else if (ch === ',' && !inQ) { result.push(cur.trim()); cur = ''; }
            else { cur += ch; }
          }
          result.push(cur.trim());
          return result;
        }

        // 헤더에서 컬럼 인덱스 찾기
        const headers = parseCSVLine(lines[0]).map(h => h.replace(/^"|"$/g, '').toLowerCase());
        const iName = headers.findIndex(h => h.includes('이름') || h.includes('name'));
        const iLat  = headers.findIndex(h => h.includes('위도') || h === 'lat' || h === 'latitude');
        const iLng  = headers.findIndex(h => h.includes('경도') || h === 'lng' || h === 'lon' || h === 'longitude');
        const iAddr = headers.findIndex(h => h.includes('주소') || h.includes('address'));

        // 헤더 없으면 기본값: 0=번호,1=이름,2=위도,3=경도,4=주소
        const hasHeader = iLat !== -1 && iLng !== -1;
        const startIdx  = hasHeader ? 1 : 0;
        const ci = {
          name: hasHeader ? iName : 1,
          lat:  hasHeader ? iLat  : 2,
          lng:  hasHeader ? iLng  : 3,
          addr: hasHeader ? iAddr : 4,
        };

        lines.slice(startIdx).forEach(line => {
          if (!line.trim()) return;
          const cols = parseCSVLine(line);
          const lat = parseFloat(cols[ci.lat]);
          const lng = parseFloat(cols[ci.lng]);
          if (isNaN(lat) || isNaN(lng)) return;
          const latlng = new kakao.maps.LatLng(lat, lng);
          bounds.extend(latlng);
          const raw = cols[ci.name] || (ci.addr >= 0 ? cols[ci.addr] : '') || '마커';
          const markerName = raw.replace(/^"|"$/g, '');
          addMarker(latlng, markerName);
        });
        if (!bounds.isEmpty()) map.setBounds(bounds);
      };
      reader.readAsText(file, 'utf-8');
    }
  });
});

async function loadKMZ(file, bounds) {
  try {
    // .kmz 또는 .zip 확장자 모두 허용 (KMZ는 ZIP 기반이므로 동일하게 처리)
    const fname = file.name.toLowerCase();
    if (!fname.endsWith('.kmz') && !fname.endsWith('.zip')) {
      alert('KMZ 또는 ZIP 파일만 불러올 수 있습니다.');
      return;
    }
    const zip = await JSZip.loadAsync(file);
    const zipFiles = Object.keys(zip.files);

    // 파일명의 널문자(\u0000) 제거 후 .kml 탐색
    let kmlText = null;
    for (const name of zipFiles) {
      const cleanName = name.replace(/\0/g, '');
      if (/\.kml$/i.test(cleanName)) {
        try {
          const text = await zip.files[name].async('string');
          if (text && text.length > 0) { kmlText = text; break; }
        } catch(e) {}
      }
    }
    if (!kmlText) { alert('KMZ 안에 .kml 파일이 없습니다.'); return; }

    const xml = new DOMParser().parseFromString(kmlText, 'application/xml');
    const placemarks = Array.from(xml.getElementsByTagName('Placemark'));

    for (const pm of placemarks) {
      const pmName = pm.getElementsByTagName('name')[0]?.textContent?.trim()
                  || pm.getElementsByTagName('n')[0]?.textContent?.trim()
                  || '설명 없음';
      const lineString = pm.getElementsByTagName('LineString')[0];
      const point = pm.getElementsByTagName('Point')[0];

      // photoFile 읽기 방법 1: Data 태그
      let photoFilename = '';
      const dataEls = pm.getElementsByTagName('Data');
      for (const d of Array.from(dataEls)) {
        if (d.getAttribute('name') === 'photoFile') {
          photoFilename = d.getElementsByTagName('value')[0]?.textContent || '';
          break;
        }
      }

      // photoFile 읽기 방법 2: description 안의 <img src="..."> 추출 (CDATA 포함)
      if (!photoFilename) {
        const descEl = pm.getElementsByTagName('description')[0];
        if (descEl) {
          const descText = descEl.textContent || '';
          const imgMatch = descText.match(/src=["']([^"']+\.(jpe?g|png))["']/i)
                        || descText.match(/src=([^\s>]+\.(jpe?g|png))/i);
          if (imgMatch) {
            const thumbPath = imgMatch[1].trim();
            const rollPath = thumbPath.replace('_thumb.', '_roll.');
            const rollEntry = zipFiles.find(z => {
              const c = z.replace(/\0/g, '');
              return c === rollPath || c.endsWith('/' + rollPath.split('/').pop());
            });
            photoFilename = rollEntry ? rollPath : thumbPath;
          }
        }
      }

      if (lineString) {
        const coordsText = lineString.getElementsByTagName('coordinates')[0]?.textContent || '';
        const pts = coordsText.trim().split(/\s+/).map(c => {
          const [lng, lat] = c.split(',').map(Number);
          return new kakao.maps.LatLng(lat, lng);
        }).filter(ll => !isNaN(ll.getLat()) && !isNaN(ll.getLng()));
        if (pts.length) {
          const poly = new kakao.maps.Polyline({ map, path: pts, strokeWeight: 4, strokeColor: getRandomColor(), strokeOpacity: 0.9 });
          pts.forEach(p => bounds.extend(p));
          polylines.push(poly);
          attachPolylineRightClick(poly);
        }
      } else if (point) {
        const coordsText = point.getElementsByTagName('coordinates')[0]?.textContent || '';
        const [lng, lat] = coordsText.trim().split(',').map(Number);
        if (isNaN(lat) || isNaN(lng)) continue;
        const ll = new kakao.maps.LatLng(lat, lng);
        bounds.extend(ll);

        if (photoFilename) {
          const baseName = photoFilename.split('/').pop();
          let photoZipFile = null;
          for (const name of zipFiles) {
            const cleanName = name.replace(/\0/g, '');
            if (cleanName === photoFilename ||
                cleanName === `files/${photoFilename}` ||
                cleanName === `images/${baseName}` ||
                cleanName === `photo/${baseName}` ||
                cleanName.endsWith('/' + baseName) ||
                cleanName === baseName) {
              photoZipFile = zip.files[name];
              break;
            }
          }
          if (photoZipFile) {
            const base64 = await photoZipFile.async('base64');
            const ext = baseName.split('.').pop().toLowerCase();
            const mime = ext === 'png' ? 'image/png' : 'image/jpeg';
            addPhotoMarker(ll, `data:${mime};base64,${base64}`, pmName);
          } else {
            addMarker(ll, pmName);
          }
        } else {
          addMarker(ll, pmName);
        }
      }
    }
    if (!bounds.isEmpty()) map.setBounds(bounds);
  } catch (err) {
    console.error(err);
    alert('KMZ 파일을 읽는 중 오류가 발생했습니다: ' + err.message);
  }
}

