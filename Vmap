// ─── 이미지 압축 (저장 시 500KB 이하) ────────────────
function compressImage(imgSrc) {
  return new Promise(resolve => {
    const qVal = parseInt(document.getElementById('photoQuality')?.value ?? '300');
    if (qVal === 0) { resolve(imgSrc); return; } // 원본 그대로
    const img = new Image();
    img.onload = () => {
      const TARGET = qVal * 1024;
      const canvas = document.createElement('canvas');
      const MAX = 1920;
      let w = img.width, h = img.height;
      if (w > MAX || h > MAX) {
        if (w > h) { h = Math.round(h * MAX / w); w = MAX; }
        else       { w = Math.round(w * MAX / h); h = MAX; }
      }
      canvas.width = w; canvas.height = h;
      canvas.getContext('2d').drawImage(img, 0, 0, w, h);
      let quality = 0.85;
      let result = canvas.toDataURL('image/jpeg', quality);
      while (result.length * 0.75 > TARGET && quality > 0.1) {
        quality = Math.round((quality - 0.05) * 100) / 100;
        result = canvas.toDataURL('image/jpeg', quality);
      }
      resolve(result);
    };
    img.src = imgSrc;
  });
}

function downloadCompressedImage(imgSrc, filename, maxWidth = 1600, quality = 0.98) {
  const img = new Image();
  img.crossOrigin = 'anonymous';
  img.onload = () => {
    const scale = maxWidth / img.width;
    const canvas = document.createElement('canvas');
    canvas.width = maxWidth;
    canvas.height = img.height * scale;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
    canvas.toBlob(blob => {
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      a.click();
      URL.revokeObjectURL(url);
    }, 'image/jpeg', quality);
  };
  img.src = imgSrc;
}

// ─── 사진 다운로드 공통 함수 (photoQuality 선택값 적용) ─
function downloadPhotoWithGPS(imgSrc, name, lat, lng) {
  return new Promise(resolve => {
    const qVal = parseInt(document.getElementById('photoQuality')?.value ?? '500');

    const toDMS = val => {
      const abs = Math.abs(val);
      const deg = Math.floor(abs);
      const min = Math.floor((abs - deg) * 60);
      const sec = (abs - deg - min / 60) * 3600;
      return [[deg, 1], [min, 1], [Math.round(sec * 100), 100]];
    };

    const insertGPS = (dataUrl) => {
      try {
        let exif = {};
        try { exif = piexif.load(dataUrl); } catch(e) {}
        if (exif["0th"]) {
          delete exif["0th"][piexif.ImageIFD.UserComment];
          delete exif["0th"][piexif.ImageIFD.ImageDescription];
        }
        if (exif["Exif"]) delete exif["Exif"][piexif.ExifIFD.UserComment];
        if (!exif["GPS"]) exif["GPS"] = {};
        exif["GPS"][piexif.GPSIFD.GPSLatitudeRef]  = lat >= 0 ? "N" : "S";
        exif["GPS"][piexif.GPSIFD.GPSLatitude]     = toDMS(lat);
        exif["GPS"][piexif.GPSIFD.GPSLongitudeRef] = lng >= 0 ? "E" : "W";
        exif["GPS"][piexif.GPSIFD.GPSLongitude]    = toDMS(lng);
        return piexif.insert(piexif.dump(exif), dataUrl);
      } catch(e) { return dataUrl; }
    };

    const doDownload = (dataUrl) => {
      const result = insertGPS(dataUrl);
      const a = document.createElement('a');
      a.href = result;
      a.download = (name || 'image') + '.jpg';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      setTimeout(resolve, 300);
    };

    // 원본: Canvas 없이 EXIF GPS만 삽입해서 저장
    if (qVal === 0) {
      doDownload(imgSrc);
      return;
    }

    // 용량 압축: Canvas로 리사이즈 + quality 조절
    const TARGET = qVal * 1024;
    const image = new Image();
    image.onload = () => {
      const MAX = 1920;
      let w = image.width, h = image.height;
      if (w > MAX || h > MAX) {
        if (w > h) { h = Math.round(h * MAX / w); w = MAX; }
        else       { w = Math.round(w * MAX / h); h = MAX; }
      }
      const canvas = document.createElement('canvas');
      canvas.width = w; canvas.height = h;
      canvas.getContext('2d').drawImage(image, 0, 0, w, h);
      let quality = 0.92;
      let result = canvas.toDataURL('image/jpeg', quality);
      while (result.length * 0.75 > TARGET && quality > 0.1) {
        quality = Math.round((quality - 0.05) * 100) / 100;
        result = canvas.toDataURL('image/jpeg', quality);
      }
      doDownload(result);
    };
    image.src = imgSrc;
  });
}

async function downloadAllPhotos() {
  const seenMarkers = new Set();
  const seenIw = new Set();
  const photoMarkers = markers.filter(m => {
    if (!m.marker || !m.marker.getMap()) return false;
    if (seenMarkers.has(m.marker) || seenIw.has(m.iw)) return false;
    seenMarkers.add(m.marker);
    seenIw.add(m.iw);
    const img = m.iw.getContent().querySelector('img');
    return img && img.src.startsWith('data:image');
  });

  for (const m of photoMarkers) {
    const img = m.iw.getContent().querySelector('img');
    const latlng = m.marker.getPosition3();
    await downloadPhotoWithGPS(img.src, m.name, latlng.getLat(), latlng.getLng());
  }
}
