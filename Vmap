document.addEventListener('paste', async e => {
  const items = Array.from(e.clipboardData?.items || []);
  const imageItem = items.find(item => item.type.startsWith('image/'));
  if (!imageItem) return;
  e.preventDefault();

  const file = imageItem.getAsFile();
  if (!file) return;

  const reader = new FileReader();
  reader.onload = ev => {
    const imgSrc = ev.target.result;
    const img = new Image();
    img.onload = () => {
      // EXIF GPS 확인
      let lat = null, lng = null;
      try {
        const exif = piexif.load(imgSrc);
        const gps = exif['GPS'];
        if (gps && gps[piexif.GPSIFD.GPSLatitude] && gps[piexif.GPSIFD.GPSLongitude]) {
          const toDec = (dms, ref) => {
            const d = dms[0][0]/dms[0][1];
            const m = dms[1][0]/dms[1][1];
            const s = dms[2][0]/dms[2][1];
            return (d + m/60 + s/3600) * ((ref === 'S' || ref === 'W') ? -1 : 1);
          };
          const _lat = toDec(gps[piexif.GPSIFD.GPSLatitude],  gps[piexif.GPSIFD.GPSLatitudeRef]  || 'N');
          const _lng = toDec(gps[piexif.GPSIFD.GPSLongitude], gps[piexif.GPSIFD.GPSLongitudeRef] || 'E');
          if (!isNaN(_lat) && !isNaN(_lng) && (_lat !== 0 || _lng !== 0)) {
            lat = _lat; lng = _lng;
          }
        }
      } catch(ex) {}

      const center = (lat && lng)
        ? new kakao.maps.LatLng(lat, lng)
        : map.getCenter();

      const now = new Date();
      const name = `붙여넣기_${now.getFullYear()}${String(now.getMonth()+1).padStart(2,'0')}${String(now.getDate()).padStart(2,'0')}_${String(now.getHours()).padStart(2,'0')}${String(now.getMinutes()).padStart(2,'0')}${String(now.getSeconds()).padStart(2,'0')}`;

